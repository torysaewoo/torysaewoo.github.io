---
import type { Project } from '../data/projects';
interface Props { project: Project }
const { project } = Astro.props;
---
<article class="card">
  <a class="thumb" href={project.live ?? project.repo} target="_blank" rel="noopener">
    <img src={`/thumbs/${project.thumbnail}`} alt={`${project.title} 스크린샷`} loading="lazy" />
  </a>
  <div class="body">
    <h3>{project.title}</h3>
    <p>{project.summary}</p>
    <div class="badges">
      {project.tech.map((t) => <span class="badge">{t}</span>)}
    </div>
    <div class="actions">
      {project.live && <a class="btn primary" href={project.live} target="_blank" rel="noopener">라이브 데모</a>}
      {project.repo && <a class="btn" href={project.repo} target="_blank" rel="noopener">GitHub</a>}
    </div>
  </div>
</article>
