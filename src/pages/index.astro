---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';

const sorted = [...projects].sort((a, b) => b.date.localeCompare(a.date));
const tickerItems = [
  'PHYSICS SIMULATION', 'REALTIME DATA', 'WEBGL', 'PROCEDURAL WORLDS',
  'THREE.JS', 'SHALLOW WATER', 'OPEN DATA', 'ZERO INSTALL',
];
---
<Base title="KSY — Creative Developer">
  <div class="container">
    <header class="hero">
      <span class="eyebrow">시뮬레이션 &amp; 데이터 — 서울, 지구</span>
      <h1>마찰은 줄이고,<br /><span class="grad">몰입은 깊게.</span></h1>
      <p class="tagline">
        브라우저에서 바로 돌아가는 인터랙티브 물리. 중력 포함, 인내심 불필요.<span class="cursor"></span>
      </p>
      <div class="links">
        <a class="btn primary" href="#projects">Explore Projects</a>
        <a class="btn" href="https://github.com/torysaewoo" target="_blank" rel="noopener">GitHub</a>
      </div>
      <span class="scroll-hint">SCROLL ↓</span>
    </header>
  </div>

  <div class="marquee" aria-hidden="true">
    <div class="track">
      {[...tickerItems, ...tickerItems].map((item) => (
        <><span>{item}</span><span class="dot">✦</span></>
      ))}
    </div>
  </div>

  <div class="container">
    <section id="projects">
      <div class="section-head">
        <span class="num">01</span>
        <h2>Projects</h2>
      </div>
      <div class="grid">
        {sorted.map((p, i) => <ProjectCard project={p} index={i + 1} />)}
      </div>
    </section>

    <section id="about">
      <div class="section-head">
        <span class="num">02</span>
        <h2>About</h2>
      </div>
      <div class="about-box">
        <p>
          시뮬레이션, 절차적 생성, 데이터 시각화처럼 <strong>"움직이는 시스템"</strong>을
          만드는 데 관심이 많습니다. 아이디어를 빠르게 실제로 돌아가는 물건으로 만들고,
          브라우저에서 누구나 바로 만져볼 수 있게 배포하는 것을 원칙으로 합니다.
        </p>
        <div class="stack">
          {['TypeScript', 'Three.js', 'Python', 'Node.js', 'Astro', 'Git'].map((t) => (
            <span class="badge">{t}</span>
          ))}
        </div>
        <p style="margin-top: 8px;">
          📮 <a href="mailto:fourweez@gmail.com">fourweez@gmail.com</a>
          &nbsp;·&nbsp;
          <a href="https://github.com/torysaewoo" target="_blank" rel="noopener">github.com/torysaewoo</a>
        </p>
      </div>
    </section>
  </div>

  <footer>
    © 2026 · BUILT WITH ASTRO · DEPLOYED ON GITHUB PAGES
  </footer>
</Base>
