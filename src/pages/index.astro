---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';

const sorted = [...projects].sort((a, b) => b.date.localeCompare(a.date));
const categories = [...new Set(sorted.map((p) => p.category))];
const tickerItems = [
  'TYPESCRIPT', 'JAVASCRIPT', 'PYTHON', 'THREE.JS', 'WEBGL',
  'NODE.JS', 'ASTRO', 'VITE', 'SVG CHARTS', 'KAKAO MAPS API',
  'REST API', 'CLOUDFLARE PAGES', 'GIT',
];
---
<Base title="KSY — Tools from Everyday Questions">
  <div class="container">
    <header class="hero">
      <h1>일상의 질문을<br /><span class="grad">도구로.</span></h1>
      <p class="tagline">
        데이터로 답하고, 시뮬레이션으로 보여주고, 브라우저로 배포합니다.<span class="cursor"></span>
      </p>
      <div class="links">
        <a class="btn primary" href="#projects">Explore Projects</a>
      </div>
      <span class="scroll-hint">SCROLL ↓</span>
    </header>
  </div>

  <div class="marquee" aria-hidden="true">
    <div class="track">
      {[...tickerItems, ...tickerItems].map((item) => (
        <><span>{item}</span><span class="dot">✦</span></>
      ))}
    </div>
  </div>

  <div class="container">
    <section id="projects">
      <div class="section-head">
        <span class="num">01</span>
        <h2>Projects</h2>
      </div>
      <div class="filter-bar" role="group" aria-label="프로젝트 카테고리 필터">
        <button class="filter-btn active" data-filter="all">전체</button>
        {categories.map((c) => (
          <button class="filter-btn" data-filter={c}>{c}</button>
        ))}
      </div>
      <div class="grid">
        {sorted.map((p, i) => <ProjectCard project={p} index={i + 1} />)}
      </div>
    </section>

    <section id="about">
      <div class="section-head">
        <span class="num">02</span>
        <h2>About</h2>
      </div>
      <div class="about-box">
        <p>
          거창한 비전보다, <strong>당장 필요한 것</strong>을 만듭니다.
          뉴스 보다 궁금해진 데이터, 일상에서 반복되는 불편, 그냥 돌려보고 싶은 시뮬레이션 —
          아이디어가 생기면 며칠 안에 돌아가는 물건으로 만들고, 누구나 링크 하나로
          써볼 수 있게 브라우저에 배포합니다. 여기 있는 건 전부 제가 먼저 쓰고 있는 것들입니다.
        </p>
        <div class="stack">
          {['TypeScript', 'Three.js', 'Python', 'Node.js', 'Astro', 'Git'].map((t) => (
            <span class="badge">{t}</span>
          ))}
        </div>
      </div>
    </section>
  </div>

  <footer>
    © 2026 KSY
  </footer>

  <script>
    // 카테고리 필터: 버튼 클릭 시 data-category가 일치하는 카드만 표시
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.card[data-category]');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.dataset.filter;
        cards.forEach((card) => {
          card.style.display =
            filter === 'all' || card.dataset.category === filter ? '' : 'none';
        });
      });
    });
  </script>
</Base>
